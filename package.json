{
  "name": "@metorial/integrations-root",
  "scripts": {
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "prettier --write .",
    "integrations:format": "prettier --write \"integrations/**/*\" --ignore-unknown",
    "integrations:cli": "bun packages/cli/src/cli.ts",
    "packages:build": "turbo run build --filter=./packages/*",
    "integrations:build:inner": "turbo run build --concurrency=1 --ui=stream --filter=./integrations/*",
    "integrations:build": "bun run packages:build && bun run integrations:build:inner"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "turbo": "^2.5.5",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.2.15"
  },
  "packageManager": "bun@1.2.15",
  "workspaces": [
    "packages/*",
    "integrations/*"
  ],
  "dependencies": {
    "@types/bun": "^1.3.12"
  }
}